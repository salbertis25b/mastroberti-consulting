---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Dashboard — Mastroberti Consulting">
  <div id="content" style="display:none" class="min-h-screen bg-[#0a0a0a]">

    <!-- Header -->
    <header class="border-b border-[#1e1e1e] px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <img src="/logo.svg" alt="Mastroberti Consulting" class="h-10 w-auto" />
        <span class="text-[#9A7020] text-xs tracking-widest uppercase">Client Portal</span>
      </div>
      <div class="flex items-center gap-4">
        <span id="user-email" class="text-[#555] text-sm"></span>
        <button id="change-pwd-btn"
          class="text-[#333] text-xs tracking-widest uppercase hover:text-[#9A7020] transition-colors mr-4">
          Change Password
        </button>
        <button id="logout-btn"
          class="text-[#333] text-xs tracking-widest uppercase hover:text-[#9A7020] transition-colors">
          Logout
        </button>
      </div>
    </header>

    <!-- Change Password Modal -->
    <div id="pwd-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:50;display:none;align-items:center;justify-content:center;">
      <div class="bg-[#0f0f0f] border border-[#1e1e1e] rounded-sm p-8 w-full max-w-md mx-4">
        <h2 class="text-white text-sm tracking-widest uppercase mb-6">Change Password</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-[#555] text-xs tracking-widest uppercase mb-2">New Password</label>
            <input type="password" id="new-pwd"
              class="w-full bg-[#111] border border-[#2a2a2a] text-white px-4 py-3 rounded-sm
                    focus:outline-none focus:border-[#9A7020] transition-colors text-sm" />
          </div>
          <div>
            <label class="block text-[#555] text-xs tracking-widest uppercase mb-2">Confirm Password</label>
            <input type="password" id="confirm-pwd"
              class="w-full bg-[#111] border border-[#2a2a2a] text-white px-4 py-3 rounded-sm
                    focus:outline-none focus:border-[#9A7020] transition-colors text-sm" />
          </div>
          <p id="pwd-error" style="display:none" class="text-red-400 text-xs"></p>
          <p id="pwd-success" style="display:none" class="text-green-400 text-xs">Password updated successfully.</p>
        </div>
        <div class="flex gap-3 mt-6">
          <button id="save-pwd-btn"
            class="bg-[#9A7020] text-[#0a0a0a] px-6 py-3 text-xs tracking-widest
                  uppercase hover:bg-[#C8A030] transition-colors rounded-sm">
            Save
          </button>
          <button id="close-pwd-btn"
            class="border border-[#2a2a2a] text-[#555] px-6 py-3 text-xs tracking-widest
                  uppercase hover:border-[#9A7020] hover:text-[#9A7020] transition-colors rounded-sm">
            Cancel
          </button>
        </div>
      </div>
    </div>

    <!-- Main -->
    <main class="max-w-4xl mx-auto px-6 py-12 space-y-6">

      <!-- Welcome -->
      <div>
        <h1 id="welcome" class="text-white text-2xl font-light tracking-widest mb-2"></h1>
        <p class="text-[#777] text-sm">
          Upload your company documents. The more context you provide, the deeper the diagnostic.
        </p>
      </div>

      <!-- Audit Status -->
      <div class="border border-[#1e1e1e] rounded-sm p-6 flex items-center gap-4">
        <div class="w-2 h-2 rounded-full bg-[#9A7020] shrink-0"></div>
        <span id="status-text" class="text-white text-sm">Initiated — awaiting documents</span>
      </div>

      <!-- Confirm Audit -->
      <div id="confirm-section">

        <!-- Pending -->
        <div id="confirm-pending" class="border border-[#9A7020] rounded-sm p-6 space-y-4">
          <p class="text-[#aaa] text-sm leading-relaxed">
            Once you have uploaded all necessary documents, confirm the start of your audit.
            <strong class="text-white"> This action is irreversible</strong> — after confirmation
            you will not be able to upload additional documents and the 5-business-day
            delivery period begins immediately.
          </p>
          <p class="text-[#777] text-xs leading-relaxed">
            By clicking the button below you confirm that you have read and agree to the
            <a href="https://mastroberti.io/tos" target="_blank"
               class="text-[#9A7020] underline hover:text-[#C8A030]">Terms of Service</a>.
            This confirmation is legally binding and constitutes the official start
            of your organizational audit engagement.
          </p>
          <button id="confirm-btn" style="display:none"
            class="border border-[#9A7020] text-[#9A7020] px-8 py-3 text-xs tracking-widest
                   uppercase hover:bg-[#9A7020] hover:text-[#0a0a0a] transition-colors rounded-sm">
            I have uploaded all necessary documents — Start my audit
          </button>
        </div>

        <!-- Confirmed -->
        <div id="confirm-done" style="display:none" class="border border-[#1e1e1e] rounded-sm p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-2 h-2 rounded-full" style="background:#22c55e"></div>
            <span class="text-white text-sm">Audit confirmed and in progress</span>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div class="border border-[#1e1e1e] rounded-sm p-4">
              <p class="text-[#555] text-xs tracking-widest uppercase mb-1">Start Date</p>
              <p id="start-date" class="text-white text-sm"></p>
            </div>
            <div class="border border-[#1e1e1e] rounded-sm p-4">
              <p class="text-[#555] text-xs tracking-widest uppercase mb-1">Delivery Deadline</p>
              <p id="delivery-date" class="text-[#9A7020] text-sm font-medium"></p>
            </div>
          </div>
          <div class="border border-[#1e1e1e] rounded-sm p-4">
            <p class="text-[#555] text-xs tracking-widest uppercase mb-2">Time Remaining</p>
            <p id="countdown" class="text-white text-2xl font-light tracking-widest mb-3"></p>
            <p class="text-[#333] text-xs leading-relaxed">
              The delivery deadline is calculated on 5 working days based on the public holiday
              calendar of North Rhine-Westphalia, Germany, where the consultant is based.
              Weekends and public holidays are excluded.
            </p>
          </div>
        </div>

      </div>

      <!-- Tabbed Window -->
      <div class="border border-[#1e1e1e] rounded-sm overflow-hidden">

        <!-- Tab Bar -->
        <div class="flex border-b border-[#1e1e1e]">
          <button id="tab-uploads"
            class="px-6 py-3 text-xs tracking-widest uppercase transition-colors
                   border-b-2 border-[#9A7020] text-[#9A7020] bg-[#0f0f0f]">
            Your Documents
          </button>
          <button id="tab-deliverables"
            class="px-6 py-3 text-xs tracking-widest uppercase transition-colors
                   border-b-2 border-transparent text-[#555] hover:text-[#9A7020] bg-[#0a0a0a]">
            Audit Documents
          </button>
          <button id="tab-messages"
            class="px-6 py-3 text-xs tracking-widest uppercase transition-colors
                   border-b-2 border-transparent text-[#555] hover:text-[#9A7020] bg-[#0a0a0a]">
            Messages
          </button>
        </div>

        <!-- Panel 1: Your Documents -->
        <div id="panel-uploads" class="p-8">
          <div id="upload-section">
            <div id="drop-zone"
              class="border-2 border-dashed border-[#2a2a2a] rounded-sm p-10
                     text-center cursor-pointer transition-colors mb-4">
              <p class="text-[#555] text-sm mb-1">Drag & drop files here</p>
              <p class="text-[#333] text-xs">or click to select files</p>
              <input type="file" id="file-input" multiple style="display:none" />
            </div>
            <div id="selected-list" class="mb-4"></div>
            <button id="upload-btn" style="display:none"
              class="bg-[#9A7020] text-[#0a0a0a] px-6 py-3 text-xs tracking-widest
                     uppercase hover:bg-[#C8A030] transition-colors rounded-sm mb-8">
              Upload Files
            </button>
          </div>
          <p class="text-[#555] text-xs tracking-widest uppercase mb-4">Uploaded Documents</p>
          <div id="uploads-list">
            <p class="text-[#333] text-sm">No documents uploaded yet.</p>
          </div>
        </div>

        <!-- Panel 2: Audit Documents -->
        <div id="panel-deliverables" class="p-8" style="display:none">
          <p class="text-[#555] text-xs tracking-widest uppercase mb-4">
            Documents from Mastroberti Consulting
          </p>
          <div id="deliverables-list">
            <p class="text-[#333] text-sm">No audit documents available yet.</p>
          </div>
        </div>

        <!-- Panel 3: Messages -->
        <div id="panel-messages" class="p-8" style="display:none">
          <div id="messages-list" class="mb-6" style="max-height:400px;overflow-y:auto;">
            <p class="text-[#333] text-sm">No messages yet.</p>
          </div>
          <div class="border-t border-[#1e1e1e] pt-6">
            <textarea id="message-input"
              placeholder="Type your message..."
              class="w-full bg-[#111] border border-[#2a2a2a] text-white px-4 py-3 rounded-sm
                     focus:outline-none focus:border-[#9A7020] transition-colors text-sm resize-none"
              rows="3"></textarea>
            <button id="send-btn"
              class="mt-3 bg-[#9A7020] text-[#0a0a0a] px-6 py-3 text-xs tracking-widest
                     uppercase hover:bg-[#C8A030] transition-colors rounded-sm">
              Send Message
            </button>
          </div>
        </div>

      </div>

    </main>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js'

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  )

  const WORKER_URL = 'https://mastroberti-webhook.salbertis25.workers.dev'

  const { data: { session } } = await supabase.auth.getSession()

  if (!session) {
    window.location.href = '/login'
  } else {
    const user = session.user
    const nome = user.user_metadata?.nome || user.email

    const contentEl = document.getElementById('content')
    if (contentEl) contentEl.style.display = 'block'

    const welcomeEl = document.getElementById('welcome')
    const emailEl = document.getElementById('user-email')
    if (welcomeEl) welcomeEl.textContent = 'Welcome, ' + nome
    if (emailEl) emailEl.textContent = user.email || ''

    document.getElementById('logout-btn')?.addEventListener('click', async function() {
      await supabase.auth.signOut()
      window.location.href = '/login'
    })

    // ── Tab switching ──
    function attivaTab(tab) {
      const panels = { uploads: 'panel-uploads', deliverables: 'panel-deliverables', messages: 'panel-messages' }
      const tabs = { uploads: 'tab-uploads', deliverables: 'tab-deliverables', messages: 'tab-messages' }
      Object.keys(panels).forEach(function(k) {
        const panel = document.getElementById(panels[k])
        const tabEl = document.getElementById(tabs[k])
        if (panel) panel.style.display = k === tab ? 'block' : 'none'
        if (tabEl) {
          tabEl.style.borderBottomColor = k === tab ? '#9A7020' : 'transparent'
          tabEl.style.color = k === tab ? '#9A7020' : '#555'
          tabEl.style.background = k === tab ? '#0f0f0f' : '#0a0a0a'
        }
      })
    }

    document.getElementById('tab-uploads')?.addEventListener('click', function() { attivaTab('uploads') })
    document.getElementById('tab-deliverables')?.addEventListener('click', function() { attivaTab('deliverables') })
    document.getElementById('tab-messages')?.addEventListener('click', function() { attivaTab('messages') })

    // ── Conferma audit ──
    function mostraBottoneConferma() {
      const btn = document.getElementById('confirm-btn')
      if (btn) btn.style.display = 'block'
    }

    function mostraConfermato(dataInizio, dataScadenzaStr) {
      const pendingEl = document.getElementById('confirm-pending')
      const doneEl = document.getElementById('confirm-done')
      if (pendingEl) pendingEl.style.display = 'none'
      if (doneEl) doneEl.style.display = 'block'

      const uploadSection = document.getElementById('upload-section')
      if (uploadSection) { uploadSection.style.opacity = '0.35'; uploadSection.style.pointerEvents = 'none' }

      const inizio = new Date(dataInizio)
      const scadenza = dataScadenzaStr ? new Date(dataScadenzaStr) : new Date(inizio.getTime() + 7 * 24 * 60 * 60 * 1000)

      const startEl = document.getElementById('start-date')
      const deliveryEl = document.getElementById('delivery-date')
      const statusEl = document.getElementById('status-text')

      if (startEl) startEl.textContent = inizio.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' })
      if (deliveryEl) deliveryEl.textContent = scadenza.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
      if (statusEl) statusEl.textContent = 'Confirmed — audit in progress'

      function aggiornaCountdown() {
        const diff = scadenza.getTime() - new Date().getTime()
        const el = document.getElementById('countdown')
        if (!el) return
        if (diff <= 0) { el.textContent = 'Your documents are ready — go to Audit Documents to download them'; return }
        const g = Math.floor(diff / (1000 * 60 * 60 * 24))
        const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))
        const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60))
        const s = Math.floor((diff % (1000 * 60)) / 1000)
        el.textContent = g + 'd ' + h + 'h ' + m + 'm ' + s + 's'
      }
      aggiornaCountdown()
      setInterval(aggiornaCountdown, 1000)
    }

    // ── Change Password ──
    document.getElementById('change-pwd-btn')?.addEventListener('click', function() {
      const modal = document.getElementById('pwd-modal')
      if (modal) modal.style.display = 'flex'
    })

    document.getElementById('close-pwd-btn')?.addEventListener('click', function() {
      const modal = document.getElementById('pwd-modal')
      if (modal) modal.style.display = 'none'
      const newPwd = document.getElementById('new-pwd')
      const confirmPwd = document.getElementById('confirm-pwd')
      const errEl = document.getElementById('pwd-error')
      const sucEl = document.getElementById('pwd-success')
      if (newPwd) newPwd.value = ''
      if (confirmPwd) confirmPwd.value = ''
      if (errEl) errEl.style.display = 'none'
      if (sucEl) sucEl.style.display = 'none'
    })

    document.getElementById('save-pwd-btn')?.addEventListener('click', async function() {
      const newPwd = document.getElementById('new-pwd')?.value || ''
      const confirmPwd = document.getElementById('confirm-pwd')?.value || ''
      const errEl = document.getElementById('pwd-error')
      const sucEl = document.getElementById('pwd-success')

      if (errEl) errEl.style.display = 'none'
      if (sucEl) sucEl.style.display = 'none'

      if (newPwd.length < 8) {
        if (errEl) { errEl.textContent = 'Password must be at least 8 characters.'; errEl.style.display = 'block' }
        return
      }
      if (newPwd !== confirmPwd) {
        if (errEl) { errEl.textContent = 'Passwords do not match.'; errEl.style.display = 'block' }
        return
      }

      const btn = document.getElementById('save-pwd-btn')
      if (btn) btn.setAttribute('disabled', 'true')

      const { error } = await supabase.auth.updateUser({ password: newPwd })

      if (error) {
        if (errEl) { errEl.textContent = 'Error: ' + error.message; errEl.style.display = 'block' }
      } else {
        if (sucEl) sucEl.style.display = 'block'
        setTimeout(function() {
          const modal = document.getElementById('pwd-modal')
          if (modal) modal.style.display = 'none'
        }, 2000)
      }

      if (btn) btn.removeAttribute('disabled')
    })

    async function caricaStatoAudit() {
      const { data, error } = await supabase
        .from('clients')
        .select('status, confermato, data_inizio, data_scadenza')
        .eq('user_id', user.id)
        .single()
      if (!error && data && data.confermato && data.data_inizio) {
        mostraConfermato(data.data_inizio, data.data_scadenza)
      }
    }

    document.getElementById('confirm-btn')?.addEventListener('click', async function() {
      const ok = window.confirm('Are you sure? This action is irreversible.\n\n— You will not be able to upload additional documents\n— The 5-business-day delivery period begins immediately\n\nBy confirming you agree to the Terms of Service.')
      if (!ok) return
      const btn = document.getElementById('confirm-btn')
      if (!btn) return
      btn.textContent = 'Confirming...'
      btn.setAttribute('disabled', 'true')
      const res = await fetch(WORKER_URL + '/confirm-audit', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + session.access_token, 'Content-Type': 'application/json' },
      })
      if (res.ok) {
        const json = await res.json()
        mostraConfermato(json.data_inizio, json.data_scadenza)
      } else {
        btn.textContent = 'Error — please try again'
        btn.removeAttribute('disabled')
      }
    })

    // ── Upload ──
    async function caricaListaUploads() {
      const res = await fetch(WORKER_URL + '/list-uploads', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + session.access_token, 'Content-Type': 'application/json' },
      })
      if (!res.ok) return
      const { count, files } = await res.json()
      const listEl = document.getElementById('uploads-list')
      if (!listEl) return
      if (count === 0) { listEl.innerHTML = '<p style="color:#333;font-size:14px;">No documents uploaded yet.</p>'; return }
      listEl.innerHTML = files.map(function(f) {
        return '<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #1e1e1e;">' +
          '<span style="color:#9A7020;font-size:12px;">—</span>' +
          '<span style="color:#aaa;font-size:14px;">' + f + '</span></div>'
      }).join('')
      mostraBottoneConferma()
    }

    const dropZone = document.getElementById('drop-zone')
    const fileInput = document.getElementById('file-input')
    const selectedListEl = document.getElementById('selected-list')
    const uploadBtn = document.getElementById('upload-btn')
    let selectedFiles = []

    dropZone?.addEventListener('click', function() { fileInput?.click() })
    dropZone?.addEventListener('dragover', function(e) { e.preventDefault(); dropZone.style.borderColor = '#9A7020' })
    dropZone?.addEventListener('dragleave', function() { dropZone.style.borderColor = '#2a2a2a' })
    dropZone?.addEventListener('drop', function(e) { e.preventDefault(); dropZone.style.borderColor = '#2a2a2a'; aggiornaSelezionati(Array.from(e.dataTransfer?.files || [])) })
    fileInput?.addEventListener('change', function() { aggiornaSelezionati(Array.from(fileInput.files || [])) })

    function aggiornaSelezionati(files) {
      selectedFiles = selectedFiles.concat(Array.from(files))
      if (selectedListEl) {
        selectedListEl.innerHTML = selectedFiles.map(function(f) {
          return '<div style="display:flex;align-items:center;gap:12px;padding:6px 0;font-size:13px;">' +
            '<span style="color:#9A7020">—</span><span style="color:white">' + f.name + '</span>' +
            '<span style="margin-left:auto;color:#333">' + (f.size / 1024).toFixed(1) + ' KB</span></div>'
        }).join('')
      }
      if (uploadBtn && selectedFiles.length > 0) uploadBtn.style.display = 'block'
    }

    uploadBtn?.addEventListener('click', async function() {
      if (selectedFiles.length === 0) return
      uploadBtn.textContent = 'Uploading...'
      uploadBtn.setAttribute('disabled', 'true')
      let success = 0
      for (const file of selectedFiles) {
        try {
          const res = await fetch(WORKER_URL + '/upload-url', {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + session.access_token, 'Content-Type': 'application/json' },
            body: JSON.stringify({ fileName: file.name }),
          })
          if (!res.ok) throw new Error()
          const { uploadUrl } = await res.json()
          const up = await fetch(uploadUrl, { method: 'PUT', body: file, headers: { 'Content-Type': file.type || 'application/octet-stream' } })
          if (!up.ok) throw new Error()
          success++
        } catch (err) { console.error('Upload error:', file.name) }
      }
      uploadBtn.style.display = 'none'
      uploadBtn.removeAttribute('disabled')
      selectedFiles = []
      if (selectedListEl) selectedListEl.innerHTML = ''
      if (fileInput) fileInput.value = ''
      caricaListaUploads()
    })

    // ── Deliverables ──
    async function caricaDeliverables() {
      const res = await fetch(WORKER_URL + '/list-files', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + session.access_token, 'Content-Type': 'application/json' },
      })
      if (!res.ok) return
      const { files } = await res.json()
      const listEl = document.getElementById('deliverables-list')
      if (!listEl) return
      if (files.length === 0) { listEl.innerHTML = '<p style="color:#333;font-size:14px;">No audit documents available yet.</p>'; return }
      listEl.innerHTML = files.map(function(f) {
        return '<div style="display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid #1e1e1e;">' +
          '<span style="color:white;font-size:14px;flex:1">' + f.fileName + '</span>' +
          '<a href="' + f.downloadUrl + '" target="_blank" style="background:#9A7020;color:#0a0a0a;padding:6px 16px;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;border-radius:2px;">Download</a></div>'
      }).join('')
    }

    // ── Messages ──
    function renderMessaggi(messages) {
      const listEl = document.getElementById('messages-list')
      if (!listEl) return
      if (messages.length === 0) {
        listEl.innerHTML = '<p style="color:#333;font-size:14px;">No messages yet.</p>'
        return
      }
      listEl.innerHTML = messages.map(function(m) {
        const isClient = m.mittente === 'client'
        return '<div style="display:flex;flex-direction:column;align-items:' + (isClient ? 'flex-end' : 'flex-start') + ';margin-bottom:16px;">' +
          '<div style="max-width:80%;background:' + (isClient ? '#1a1a1a' : '#0f0f0f') + ';border:1px solid ' + (isClient ? '#2a2a2a' : '#9A7020') + ';padding:12px 16px;border-radius:4px;">' +
          '<p style="color:' + (isClient ? '#aaa' : '#fff') + ';font-size:14px;line-height:1.5;margin:0;">' + m.testo + '</p>' +
          '</div>' +
          '<span style="color:#333;font-size:11px;margin-top:4px;">' +
          (isClient ? 'You' : 'Mastroberti Consulting') + ' · ' +
          new Date(m.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) +
          '</span></div>'
      }).join('')
      listEl.scrollTop = listEl.scrollHeight
    }

    async function caricaMessaggi() {
      const { data, error } = await supabase
        .from('messages')
        .select('*')
        .eq('user_id', user.id)
        .order('created_at', { ascending: true })
      if (!error && data) renderMessaggi(data)
    }

    document.getElementById('send-btn')?.addEventListener('click', async function() {
      const input = document.getElementById('message-input')
      if (!input) return
      const testo = input.value.trim()
      if (!testo) return
      const btn = document.getElementById('send-btn')
      if (btn) btn.setAttribute('disabled', 'true')
      const { error } = await supabase
        .from('messages')
        .insert({ user_id: user.id, mittente: 'client', testo: testo })
      if (!error) {
        input.value = ''
        caricaMessaggi()
      }
      if (btn) btn.removeAttribute('disabled')
    })

    // ── Init ──
    caricaStatoAudit()
    caricaListaUploads()
    caricaDeliverables()
    caricaMessaggi()
  }
</script>